# Redirect bare domain to www.tradehax.net
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_HOST} ^tradehax\.net$ [NC]
  RewriteRule ^(.*)$ https://www.tradehax.net/$1 [L,R=301]
</IfModule>

# Disable directory browsing
<IfModule mod_autoindex.c>
  Options -Indexes
</IfModule>

# Prevent exposure of source files and common sensitive extensions
<IfModule mod_authz_core.c>
  <FilesMatch "\.(?:env|log|json|md|yaml|yml|sh|ts|tsx|git|lock)$">
    Require all denied
  </FilesMatch>
</IfModule>
<IfModule !mod_authz_core.c>
  <FilesMatch "\.(?:env|log|json|md|yaml|yml|sh|ts|tsx|git|lock)$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>
